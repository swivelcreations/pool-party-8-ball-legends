  m_FontData:
    m_Font: {fileID: 12800000, guid: 792fb289b1637474daa5113717db16c7, type: 3}
    m_FontSize: 25
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "Pocket as many balls as you can before the time runs out.\n\nThe rack
    consists of 15 balls. When you finish a rack within the time limit, you will
    get a new rack. For each ball pocketed, you will get 10 seconds bonus time during
    the 1st rack, 9 seconds during the 2nd rack, 8 seconds during the 3rd and so
    on. Pocketing the cue ball at any time will result in a 30 seconds penalty and
    loss of 0.5 from the multiplier.\n\nYou will earn 250 points for every object
    ball pocketed, the points will be multiplied by the multiplier and added to your
    score. \n\nMultiplier is the number which is calculated from the consecutive
    pockets up to 6 balls. The multiplier increases with half the value of consecutive
    pockets. So for example, if you pocket 4 balls without missing, then your 2 will
    be added to the multiplier.\n\nEvery consecutive miss will cause a loss of 0.5
    from the multiplier."

--- !u!114 &4101
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 797}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 792fb289b1637474daa5113717db16c7, type: 3}
    m_FontSize: 25
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "The Matrix Mode rack consists of 15 balls. Here each ball's number is
    important. Every pocketed ball will multiply or divide the score. \n\nIf the
    current pocketed ball number is greater than the previous one, then your score
    will be multiplied by the difference between these two balls.\nIf the current
    pocketed ball number is smaller than the previous one, then your score will be
    divided by the current ball number.\n\nOn the top of the screen you have 15 slots
    for 15 balls, where you can monitor your actions. \n\nThe game will be over when
    you pocket all 15 balls or pocket the cue ball once (which is called a scratch).\n\nAnd
    another exciting thing about this mode is, if you pocket 1 to 15 continuously,
    then your final score will be 1.\n\nTap and hold on the balls number button (marked
    as #) while in game, to see the ball numbers."

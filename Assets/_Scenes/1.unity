--- !u!114 &4248
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 932}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 792fb289b1637474daa5113717db16c7, type: 3}
    m_FontSize: 25
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: 'This game is played with 9 object balls numbered 1 through 9 and the cue
    ball. For the breaking shot, you must play the shot with the cue ball behind
    the head string and strike the 1-ball and either pocket any numbered ball or
    drive 4 balls to the rail. To play a legal shot, you must strike the lowest numbered
    ball that is currently on the table.


    If the cue ball is pocketed (which
    is called a scratch), the 9-ball if pocketed is spotted (returned to the table)
    and the opponent gets ball in hand anywhere on the table.


    For any shot,
    either a numbered ball must be pocketed or any ball must be driven to the rail
    after the first contact with the lowest numbered ball. If not, it is a foul.


    To
    win the game, the player has to legally pocket the 9-ball. If the player hits
    the lowest numbered ball first and pockets the 9-ball without committing a foul,
    it results in a win of the game. If only the 9-ball is on the table, then the
    next player who pockets the 9-ball wins.'
